# ============================================================
# DATABASE
# ============================================================
# Para desenvolvimento local com SQLite:
DATABASE_URL=sqlite:///./gestao_contas.db

# Para produção com Supabase (PostgreSQL):
# DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# DB_SCHEMA=gestao_contas

# Schema PostgreSQL (vazio = public). Útil para isolar tabelas
# quando o banco é compartilhado com outros projetos.
DB_SCHEMA=

# ============================================================
# JWT (autenticação)
# ============================================================
# IMPORTANTE: Gere uma chave forte para produção:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=sua-chave-secreta-aqui-mude-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================
# CORS (origens permitidas, separadas por vírgula)
# ============================================================
# Local:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Produção: adicione o domínio do frontend (Vercel, etc.)
# CORS_ORIGINS=https://gestao-contas.vercel.app,http://localhost:3000

# ============================================================
# App
# ============================================================
APP_NAME=Gestão de Contas
DEBUG=False

# ============================================================
# Upload
# ============================================================
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=/tmp/uploads
